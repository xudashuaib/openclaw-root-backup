        "kind": "agentTurn",
        "message": "RETRY_COUNT=0; MAX_RETRIES=20; RETRY_INTERVAL=600; while [ $RETRY_COUNT -lt $MAX_RETRIES ]; do rsync -av --exclude='logs/' --exclude='.git/' --exclude='.discovery/' ~/.openclaw/ ~/.openclaw-backup/ && git -C ~/.openclaw-backup add -A && git -C ~/.openclaw-backup commit -m 'Full backup $(date +%Y-%m-%d_%H:%M)' && git -C ~/.openclaw-backup push origin main && echo 'Backup succeeded' && break || { RETRY_COUNT=$((RETRY_COUNT+1)); echo \"Backup failed, retry $RETRY_COUNT/$MAX_RETRIES in ${RETRY_INTERVAL}s...\"; sleep $RETRY_INTERVAL; } || exit 0; done",
        "timeoutSeconds": 600
      },
