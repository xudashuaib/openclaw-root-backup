130|289.900|291.500|284.170|215966.000\n2026-02-11|285.000|284.590|286.500|280.500|173416.000\n2026-02-12|290.500|303.240|305.000|285.000|300674.000\n2026-02-13|303.240|308.700|317.600|301.000|299254.000\n2026-02-24|317.500|323.050|331.160|311.000|302545.000\n2026-02-25|316.000|311.320|317.010|301.960|285728.000\n2026-02-26|316.000|309.400|316.000|306.050|231053.000\n2026-02-27|303.500|300.000|306.000|296.690|220969.000\n2026-03-02|290.870|293.150|299.980|290.550|185132.000\n2026-03-03|295.000|272.890|296.100|272.590|333294.000\n2026-03-04|272.890|279.070|290.000|272.890|326916.000\n2026-03-05|288.160|282.800|289.880|280.230|255300.000\n2026-03-06|277.900|284.990|288.880|277.560|208576.000\n2026-03-09|273.000|276.090|277.700|264.000|283546.000\n2026-03-10|284.100|285.440|286.500|281.180|233537.000\n2026-03-11|288.040|281.530|290.830|281.320|216499.000\n2026-03-12|279.830|274.780|283.830|272.430|172327.000\n2026-03-13|270.780|278.330|285.670|270.780|226137.000\n2026-03-16|280.000|306.160|306.160|277.000|462736.000\n2026-03-17|306.500|296.000|313.000|295.880|390001.000\n2026-03-18|305.100|311.250|313.680|302.000|420514.000\n2026-03-19|300.000|303.680|309.710|297.000|312146.000\n2026-03-20|305.550|290.200|306.700|290.000|312536.000\n2026-03-23|277.000|273.350|282.880|271.000|282142.000\n2026-03-24|277.990|273.710|278.000|256.880|336915.000\n2026-03-25|275.150|278.400|285.800|275.140|283763.000\n2026-03-26|268.000|262.000|268.700|260.000|350773.000\n2026-03-27|248.980|258.660|260.180|240.250|289773.000\n2026-03-30|252.000|255.850|259.540|250.030|214696.000\n2026-03-31|249.900|238.100|252.000|236.860|427623.000\n2026-04-01|250.000|255.000|256.100|243.700|387958.000\n2026-04-02|257.860|246.990|259.800|245.600|252974.000\n2026-04-03|250.990|249.100|254.600|247.500|197472.000\n2026-04-07|253.100|249.660|255.960|248.810|198472.000\n2026-04-08|250.110|255.960|256.960|243.080|753325.000\n2026-04-09|250.000|250.490|253.490|243.900|444683.000\n2026-04-10|255.490|265.090|268.320|255.240|534767.000\n2026-04-13|261.000|262.140|269.840|260.900|412421.000\n2026-04-14|269.50|280.01|281.23|266.39|466205.000\"\"\"\n\n# 解析数据\ndays = []\nfor line in kdata_raw.strip().split('\\n'):\n    parts = line.split('|')\n    days.append({\n        'date': parts[0],\n        'open': float(parts[1]),\n        'close': float(parts[2]),\n        'high': float(parts[3]),\n        'low': float(parts[4]),\n        'volume': float(parts[5])\n    })\n\n# 计算EMA\ndef ema(prices, period):\n    ema_val = prices[0]\n    k = 2/(period+1)\n    result = [ema_val]\n    for p in prices[1:]:\n        ema_val = p * k + ema_val * (1-k)\n        result.append(ema_val)\n    return result\n\ncloses = [d['close'] for d in days]\nvolumes = [d['volume'] for d in days]\n\n# EMA计算\nema12 = ema(closes, 12)\nema26 = ema(closes, 26)\ndea9 = ema([e12-e26 for e12,e26 in zip(ema12,ema26)], 9)\n\n# MACD = DIF - DEA\ndif_list = [e12-e26 for e12,e26 in zip(ema12,ema26)]\nmacd_list = [(d-de)*2 for d,de in zip(dif_list, dea9)]\n\n# RSI (14日)\ndef rsi(prices, period=14):\n    gains = []\n    losses = []\n    for i in range(1, len(prices)):\n        diff = prices[i] - prices[i-1]\n        gains.append(max(diff, 0))\n        losses.append(max(-diff, 0))\n    result = [50] * period\n    avg_gain = sum(gains[:period])/period\n    avg_loss = sum(losses[:period])/period\n    if avg_loss == 0:\n        result.append(100)\n    else:\n        rs = avg_gain/avg_loss\n        result.append(100 - 100/(1+rs))\n    for i in range(period, len(gains)):\n        avg_gain = (avg_gain*(period-1) + gains[i])/period\n        avg_loss = (avg_loss*(period-1) + losses[i])/period\n        if avg_loss == 0:\n            result.append(100)\n        else:\n            rs = avg_gain/avg_loss\n            result.append(100 - 100/(1+rs))\n    return result\n\nrsi6 = rsi(closes, 6)\nrsi14 = rsi(closes, 14)\n\n# KDJ (9,3,3)\ndef kdj(highs, lows, closes, n=9, m1=3, m2=3):\n    k_list = [50]\n    d_list = [50]\n    for i in range(n, len(closes)):\n        h = max(highs[i-n:i])\n        l = min(lows[i-n:i])\n        if h == l:\n            rsv = 50\n        else:\n            rsv = (closes[i] - l) / (h - l) * 100\n        k = 2/3 * k_list[-1] + 1/3 * rsv\n        d = 2/3 * d_list[-1] + 1/3 * k\n        k_list.append(k)\n        d_list.append(d)\n    j_list = [3*k - 2*d for k,d in zip(k_list, d_list)]\n    return k_list, d_list, j_list\n\nhighs = [d['high'] for d in days]\nlows = [d['low'] for d in days]\nk_list, d_list, j_list = kdj(highs, lows, closes)\n\n# 均线\nma5 = [sum(closes[i-4:i+1])/5 for i in range(4, len(closes))]\nma10 = [sum(closes[i-9:i+1])/10 for i in range(9, len(closes))]\nma20 = [sum(closes[i-19:i+1])/20 for i in range(19, len(closes))]\nma60 = [sum(closes[i-59:i+1])/60 for i in range(59, len(closes))]\n\n# 最近几天分析\nN = len(days)\ntoday_idx = N-1\nyesterday_idx = N-2\ntwo_days_ago_idx = N-3\n\n# 打印关键指标（最后几天）\nprint(\"=== 技术指标分析 ===\")\nprint(f\"\\n今日 ({days[today_idx]['date']}) 收盘: {days[today_idx]['close']}\")\nprint(f\"昨收 ({days[yesterday_idx]['date']}): {days[yesterday_idx]['close']}\")\n\n# MACD\nprint(f\"\\n【MACD】(最后5天)\")\nfor i in range(today_idx-4, today_idx+1):\n    print(f\"  {days[i]['date']}: DIF={dif_list[i]:.3f}, DEA={dea9[i]:.3f}, MACD={macd_list[i]:.3f}\")\n\n# RSI\nprint(f\"\\n【RSI】\")\nprint(f\"  RSI6: {rsi6[-1]:.1f} (昨:{rsi6[-2]:.1f}, 前:{rsi6[-3]:.1f})\")\nprint(f\"  RSI14: {rsi14[-1]:.1f} (昨:{rsi14[-2]:.1f}, 前:{rsi14[-3]:.1f})\")\n\n# KDJ\nprint(f\"\\n【KDJ】(最近5天)\")\nk_offset = len(k_list) - N\nfor i in range(today_idx-4, today_idx+1):\n    ki = i + k_offset\n    if ki >= 0 and ki < len(k_list):\n        print(f\"  {days[i]['date']}: K={k_list[ki]:.1f}, D={d_list[ki]:.1f}, J={j_list[ki]:.1f}\")\n\n# 均线\nprint(f\"\\n【均线系统】\")\nma5_idx = today_idx - 4\nma10_idx = today_idx - 9\nma20_idx = today_idx - 19\nma60_idx = today_idx - 59\nprint(f\"  MA5={ma5[-1]:.2f}, MA10={ma10[-1]:.2f}, MA20={ma20[-1]:.2f}, MA60={ma60[-1]:.2f}\")\nprint(f\"  当前价格280.01 vs MA5:{days[today_idx]['close']-ma5[-1]:+.2f}, vs MA10:{days[today_idx]['close']-ma10[-1]:+.2f}\")\nprint(f\"  vs MA20:{days[today_idx]['close']-ma20[-1]:+.2f}, vs MA60:{days[today_idx]['close']-ma60[-1]:+.2f}\")\n\n# 均线多头排列？\nma5_above_ma10 = ma5[-1] > ma10[-1]\nma10_above_ma20 = ma10[-1] > ma20[-1]\nma20_above_ma60 = ma20[-1] > ma60[-1]\nprint(f\"  多头排列: MA5>MA10>{ma10_above_ma20}, MA10>MA20>{ma20_above_ma60}\")\n\n# 成交量分析\nprint(f\"\\n【成交量分析】\")\navg_vol20 = sum(volumes[-20:])/20\ntoday_vol = volumes[-1]\nprint(f\"  今日量: {today_vol:.0f}手 (均量20日:{avg_vol20:.0f})\")\nprint(f\"  量比: {today_vol/avg_vol20:.2f}\")\nprint(f\"  近5日量: {[f'{v:.0f}' for v in volumes[-5:]]}\")\nprint(f\"  5日均量: {sum(volumes[-5:])/5:.0f}\")\n\n# 布林带 (20日)\nma20_arr = ma20\nbb_std = (sum([(c - ma20_arr[-1])**2 for c in closes[-20:]])/20)**0.5\nbb_upper = ma20_arr[-1] + 2*bb_std\nbb_lower = ma20_arr[-1] - 2*bb_std\nprint(f\"\\n【布林带(20日)】\")\nprint(f\"  中轨(MA20): {ma20_arr[-1]:.2f}\")\nprint(f\"  上轨: {bb_upper:.2f}, 下轨: {bb_lower:.2f}\")\nprint(f\"  今日280.01处于布林上轨{bb_upper:.2f}附近，开口: {'扩张' if bb_std > (sum([(c - ma20_arr[-2])**2 for c in closes[-20:-1]])/20)**0.5 else '收缩'}\")\n\n# MACD信号\nlast_dif = dif_list[-1]\nlast_dea = dea9[-1]\nlast_macd = macd_list[-1]\nprint(f\"\\n【MACD信号】\")\nif last_dif > last_dea:\n    print(f\"  DIF({last_dif:.3f}) > DEA({last_dea:.3f}) → MACD柱状柱: {last_macd:.3f} → ✅ 金叉（多方）\")\nelse:\n    print(f\"  DIF({last_dif:.3f}) < DEA({last_dea:.3f}) → MACD柱状柱: {last_macd:.3f} → ❌ 死叉（空方）\")\n\n# 判断背离\ndif_trend_last10 = dif_list[-1] > dif_list[-3] > dif_list[-5]\nprice_trend_last10 = closes[-1] > closes[-3] > closes[-5]\nif dif_trend_last10 and not price_trend_last10:\n    print(f\"  ⚠️ 顶背离预警：DIF上升但价格上升放缓\")\nelif not dif_trend_last10 and price_trend_last10:\n    print(f\"  ⚠️ 底背离预警：DIF下降但价格下降放缓\")\nelse:\n    print(f\"  无明显背离\")\n\n# RSI信号\nprint(f\"\\n【RSI信号】\")\nif rsi14[-1] > 70:\n    print(f\"  RSI14={rsi14[-1]:.1f} → 🔴 超买区域\")\nelif rsi14[-1] < 30:\n    print(f\"  RSI14={rsi14[-1]:.1f} → 🟢 超卖区域\")\nelse:\n    print(f\"  RSI14={rsi14[-1]:.1f} → 中性区间\")\n\n# KDJ信号\nlast_k = k_list[-1]\nlast_d = d_list[-1]\nlast_j = j_list[-1]\nprint(f\"\\n【KDJ信号】\")\nif last_j > 100:\n    print(f\"  J={last_j:.1f} → 🔴 超买（极端多头）\")\nelif last_j < 0:\n    print(f\"  J={last_j:.1f} → 🟢 超卖（极端空头）\")\nelse:\n    print(f\"  J={last_j:.1f} → 中性\")\n\nif last_k > last_d:\n    print(f\"  K({last_k:.1f})>D({last_d:.1f}) → ✅ 金叉\")\nelse:\n    print(f\"  K({last_k:.1f})<D({last_d:.1f}) → ❌ 死叉\")\n\n# 支撑压力位\nprint(f\"\\n【关键支撑/压力位】\")\n# 近期低点\nrecent_lows = sorted(set([d['low'] for d in days[-10:]]))\nprint(f\"  近期低点: {recent_lows[:3]}\")\n# 近期高点\nrecent_highs = sorted(set([d['high'] for d in days[-10:]]), reverse=True)\nprint(f\"  近期高点: {recent_highs[:3]}\")\n# 历史高点\nall_highs = sorted(set([d['high'] for d in days]), reverse=True)\nprint(f\"  历史高点(60日): {all_highs[:5]}\")\n\nPYEOF"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":6036,"output":4541,"cacheRead":13979,"cacheWrite":0,"totalTokens":24556,"cost":{"input":0.0018108,"output":0.0054491999999999995,"cacheRead":0.0008387399999999999,"cacheWrite":0,"total":0.008098739999999998}},"stopReason":"toolUse","timestamp":1776150237442,"responseId":"062d19dd2942621389bf87d7e7d2e760"}}
